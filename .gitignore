# ============================================
#              .gitignore 说明
# ============================================
# 被此文件匹配的文件/文件夹不会被 git 跟踪。
# 主要用于排除编译产物、依赖包、敏感信息等。
#
# 语法规则:
#   *.log       → 匹配所有 .log 结尾的文件
#   node_modules/ → 匹配所有名为 node_modules 的文件夹
#   !important.log → 取反，强制跟踪某个被忽略的匹配项
#   .env        → 匹配根目录的 .env 文件
#   **/*.tmp    → 匹配任意深度的 .tmp 文件
# ============================================

# ========== 操作系统自动生成 ==========
# Windows 缩略图缓存
Thumbs.db
ehthumbs.db
Desktop.ini
# Windows 回收站
$RECYCLE.BIN/

# macOS 文件夹属性/搜索索引
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux 临时文件
*~

# ========== 编辑器 / IDE ==========
# VS Code
.vscode/
*.code-workspace

# JetBrains 全家桶 (IntelliJ / PyCharm / WebStorm 等)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# ========== Python ==========
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
venv/
.venv/
env/

# ========== Node.js / 前端 ==========
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
.next/
.nuxt/
.cache/

# ========== Java ==========
*.class
*.jar
*.war
*.nar
target/
!.mvn/wrapper/maven-wrapper.jar
*.log

# ========== C/C++ ==========
*.o
*.obj
*.out
*.exe
*.dll
*.a
*.so
*.dylib

# ========== 编译/构建产物 ==========
bin/
obj/
out/
build/
release/
debug/

# ========== 敏感信息 / 本地配置 ==========
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.yaml
config.local.*

# 不想上传的本地笔记/草稿（自己酌情使用）
# notes/
# drafts/

# ========== 通用日志/临时文件 ==========
*.log
*.tmp
*.temp
.cache/
tmp/
temp/

# ========== 压缩包/大文件 ==========
*.zip
*.tar.gz
*.rar
*.7z
